@model List<SmsProject.Models.Contact>
@{
    ViewData["Title"] = "Address Book";
}

<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-end;">
    <div>
        <h1 class="page-title">Directory</h1>
        <p class="page-subtitle">Offline address book for unverified nodes.</p>
    </div>
    <button onclick="document.getElementById('addModal').classList.add('open')" class="btn btn-primary btn-lg">
        <i data-lucide="plus-circle" style="width: 18px;"></i> Add Entry
    </button>
</div>

<div class="card" style="padding: 40px; min-height: 500px;">
    @if (Model.Count == 0)
    {
        <div class="flex-center" style="flex-direction: column; height: 300px; opacity: 0.5;">
            <div class="icon-box icon-box-indigo" style="width: 80px; height: 80px; margin-bottom: 24px;">
                <i data-lucide="book-dashed" style="width: 40px; height: 40px;"></i>
            </div>
            <h3 style="font-size: 1.2rem; margin-bottom: 8px;">Directory Empty</h3>
            <p style="color: var(--text-tertiary);">No entries found in local storage.</p>
        </div>
    }
    else
    {
        <div class="grid-3">
            @foreach (var contact in Model)
            {
                <div class="card" style="padding: 24px; border: 1px solid rgba(255,255,255,0.05); background: rgba(0,0,0,0.2);">
                    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
                        <div class="icon-box icon-box-cyan" style="width: 48px; height: 48px;">
                            <i data-lucide="user-square-2"></i>
                        </div>
                        <div>
                            <div style="font-size: 1.1rem; font-weight: 700; color: var(--text);">@contact.Name</div>
                            <div style="font-size: 0.8rem; color: var(--text-tertiary);">Entry: @contact.CreatedAt.ToString("yy.MM.dd")</div>
                        </div>
                    </div>
                    
                    <div style="background: var(--bg); padding: 12px 16px; border-radius: var(--radius-sm); border: 1px dashed var(--border); display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                        <span style="font-family: monospace; font-size: 1.05rem; letter-spacing: 2px; color: var(--cyan);">@contact.MobileNumber</span>
                        <i data-lucide="copy" style="width: 16px; color: var(--text-tertiary); cursor: pointer;" title="Copy to clipboard"></i>
                    </div>

                    <div style="display: flex; gap: 12px;">
                        <a href="/Sms/Index?to=@contact.MobileNumber" class="btn btn-ghost" style="flex: 1; justify-content: center;">Route Msg</a>
                        <form asp-action="RemoveContact" asp-controller="Social" method="post">
                            <input type="hidden" name="contactId" value="@contact.Id" />
                            <button type="submit" class="btn btn-danger" style="padding: 10px 14px; border-radius: var(--radius-sm);">
                                <i data-lucide="trash" style="width: 16px; margin: 0;"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Add Modal -->
<div id="addModal" class="modal-overlay">
    <div class="modal card-glow">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
            <h3 style="font-size: 1.4rem; font-weight: 700; display: flex; align-items: center; gap: 12px;">
                <div class="icon-box icon-box-indigo" style="width: 32px; height: 32px;"><i data-lucide="file-plus-2" style="width:16px;"></i></div> New Entry
            </h3>
            <button onclick="document.getElementById('addModal').classList.remove('open')" style="background: none; border: none; color: var(--text-tertiary); cursor: pointer;"><i data-lucide="x"></i></button>
        </div>

        <form asp-action="AddContact" asp-controller="Social" method="post">
            <div class="form-group">
                <label class="form-label">Classification / Name</label>
                <div class="input-icon-wrap">
                    <i data-lucide="tag" class="icon"></i>
                    <input name="name" class="form-input" placeholder="e.g. Alpha Lead" required />
                </div>
            </div>
            <div class="form-group" style="margin-bottom: 32px;">
                <label class="form-label">Routing Number</label>
                <div class="input-icon-wrap">
                    <i data-lucide="hash" class="icon"></i>
                    <input name="mobile" class="form-input" placeholder="e.g. 03001234567" required />
                </div>
            </div>
            <div style="display: flex; gap: 16px;">
                <button type="button" onclick="document.getElementById('addModal').classList.remove('open')" class="btn btn-ghost" style="flex: 1; justify-content: center;">Abort</button>
                <button type="submit" class="btn btn-primary" style="flex: 1; justify-content: center;">Save Entry</button>
            </div>
        </form>
    </div>
</div>
