@{
    ViewData["Title"] = "Social Circle";
}

<div class="container">
    <div class="dashboard-grid">
        <!-- Send Friend Request -->
        <div class="card glass-card">
            <h3>Find Friends</h3>
            <p class="text-muted mb-4">Search by email to send a request.</p>
            <form asp-action="SendRequest" method="post">
                <div class="form-group">
                    <input name="emailId" class="form-control" placeholder="friend@email.com" required />
                </div>
                <button type="submit" class="btn-primary">Send Request</button>
            </form>
        </div>

        <!-- Pending Requests -->
        <div class="card glass-card">
            <h3>Pending Requests</h3>
            <div class="mt-4">
                @foreach (var req in ViewBag.Requests as List<SmsProject.Data.Friendship>)
                {
                    <div class="glass-card mb-2" style="padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
                        <span>From: User #@req.User1Id</span>
                        <div style="display: flex; gap: 0.5rem;">
                            <form asp-action="HandleRequest" method="post" style="display: inline;">
                                <input type="hidden" name="requestId" value="@req.Id" />
                                <input type="hidden" name="status" value="Accepted" />
                                <button type="submit" class="btn-primary" style="padding: 0.25rem 0.75rem;">Accept</button>
                            </form>
                            <form asp-action="HandleRequest" method="post" style="display: inline;">
                                <input type="hidden" name="requestId" value="@req.Id" />
                                <input type="hidden" name="status" value="Rejected" />
                                <button type="submit" class="btn-link text-danger">Reject</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- My Friends -->
    <div class="card glass-card mt-4">
        <h3>My Friends</h3>
        <div class="dashboard-grid mt-4">
            @foreach (var friend in ViewBag.MyFriends as List<SmsProject.Data.Friendship>)
            {
                <div class="glass-card text-center" style="padding: 2rem;">
                    <i data-lucide="user" style="width: 48px; height: 48px; color: var(--primary);"></i>
                    <h5 class="mt-3">Friend #@friend.Id</h5>
                    <p class="text-muted">Connected</p>
                    <a asp-controller="Sms" asp-action="Index" class="btn-secondary mt-2 d-inline-block">Message</a>
                </div>
            }
        </div>
    </div>
</div>
