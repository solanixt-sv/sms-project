@model dynamic
@{
    ViewData["Title"] = "My Friends";
}

<div style="margin-bottom: 40px;">
    <h1 class="text-gradient" style="font-size: 2.2rem; font-weight: 700; margin-bottom: 8px;">Social Circle</h1>
    <p style="color: var(--text-muted);">Manage your friends and pending requests</p>
</div>

<div style="display: grid; grid-template-columns: 1fr 350px; gap: 40px; align-items: start;">
    <!-- Left: Friends List -->
    <div class="glass-card">
        <h3 style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
            <i data-lucide="users" style="color: var(--primary);"></i> Active Friends
        </h3>
        
        @if (Model.Friends.Count == 0)
        {
            <div style="text-align: center; padding: 60px 0;">
                <i data-lucide="user-minus" style="width: 48px; height: 48px; color: var(--glass-border); margin-bottom: 16px;"></i>
                <p style="color: var(--text-muted);">No active friends yet. Start connecting!</p>
            </div>
        }
        else
        {
            <div style="display: grid; gap: 16px;">
                @foreach (var friend in Model.Friends)
                {
                    <div style="background: rgba(255, 255, 255, 0.02); padding: 20px; border-radius: 16px; border: 1px solid var(--glass-border); display: flex; justify-content: space-between; align-items: center;">
                        <div style="display: flex; align-items: center; gap: 16px;">
                            <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--accent)); display: flex; align-items: center; justify-content: center; font-weight: 700;">
                                @friend.Username[0].ToString().ToUpper()
                            </div>
                            <div>
                                <div style="font-weight: 600;">@friend.Username</div>
                                <div style="font-size: 0.85rem; color: var(--text-muted);">@friend.Mobile</div>
                            </div>
                        </div>
                        <a href="/Sms/Index?to=@friend.Mobile" class="btn-primary" style="padding: 10px 20px; font-size: 0.85rem;">Message</a>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Right: Pending Requests -->
    <div class="glass-card">
        <h3 style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px;">
            <i data-lucide="user-plus" style="color: var(--secondary);"></i> Pending Requests
        </h3>

        <div style="display: grid; gap: 16px;">
            @foreach (var req in Model.PendingRequests)
            {
                <div style="background: rgba(255, 255, 255, 0.03); padding: 16px; border-radius: 16px; border: 1px solid var(--glass-border);">
                    <div style="font-weight: 600; margin-bottom: 4px;">@req.Requester.Username</div>
                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 16px;">wants to be your friend</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <form asp-action="AcceptFriend" asp-controller="Social" method="post">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <button type="submit" class="btn-primary" style="width: 100%; padding: 8px; font-size: 0.8rem;">Accept</button>
                        </form>
                        <form asp-action="RejectFriend" asp-controller="Social" method="post">
                            <input type="hidden" name="requestId" value="@req.Id" />
                            <button type="submit" class="btn-primary" style="width: 100%; padding: 8px; font-size: 0.8rem; background: rgba(236, 72, 153, 0.1); color: var(--secondary); box-shadow: none;">Reject</button>
                        </form>
                    </div>
                </div>
            }
            @if (Model.PendingRequests.Count == 0)
            {
                <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 20px;">No pending requests.</p>
            }
        </div>

        <div style="margin-top: 32px; border-top: 1px solid var(--glass-border); padding-top: 24px;">
            <h4 style="font-size: 0.9rem; margin-bottom: 16px;">Add New Friend</h4>
            <form asp-action="SendFriendRequest" asp-controller="Social" method="post">
                <input name="friendUsername" class="form-input" placeholder="Enter username" style="margin-bottom: 12px;" required />
                <button type="submit" class="btn-primary" style="width: 100%; padding: 10px; font-size: 0.85rem;">Send Request</button>
            </form>
        </div>
    </div>
</div>
