@model SmsProject.Models.ApplicationUser
@{
    ViewData["Title"] = "Premium Services";
}

<div style="text-align: center; margin-bottom: 60px;">
    <h1 class="text-gradient" style="font-size: 2.8rem; font-weight: 700; margin-bottom: 16px;">Elevate Your Experience</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">Upgrade to premium and unlock unlimited messaging, global delivery, and priority support.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; justify-content: center; max-width: 1000px; margin: 0 auto;">
    
    <!-- Free Plan -->
    <div class="glass-card" style="display: flex; flex-direction: column; opacity: 0.8;">
        <div style="margin-bottom: 30px;">
            <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">Current Plan</span>
            <h2 style="font-size: 2rem; margin-top: 10px;">Free Tier</h2>
        </div>
        <div style="flex-grow: 1;">
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 16px;">
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="check-circle" style="color: #10b981; width: 18px;"></i> 5 Messages / Month (Non-friends)
                </li>
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="check-circle" style="color: #10b981; width: 18px;"></i> Unlimited Friend Messages
                </li>
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem; color: var(--text-muted);">
                    <i data-lucide="x-circle" style="width: 18px;"></i> Priority Delivery
                </li>
            </ul>
        </div>
        @if (Model.IsPremium) {
            <div style="margin-top: 40px; text-align: center; color: var(--text-muted);">Downgrade not available</div>
        } else {
            <button class="btn-primary" style="margin-top: 40px; background: rgba(255,255,255,0.05); color: var(--text-muted); box-shadow: none; cursor: default;">Active</button>
        }
    </div>

    <!-- Premium Plan -->
    <div class="glass-card" style="border: 2px solid var(--primary); transform: scale(1.05); position: relative; overflow: hidden;">
        <div style="position: absolute; top: 12px; right: -30px; background: var(--secondary); padding: 4px 40px; transform: rotate(45deg); font-size: 0.75rem; font-weight: 700; box-shadow: 0 5px 10px rgba(0,0,0,0.3);">POPULAR</div>
        
        <div style="margin-bottom: 30px;">
            <span class="badge badge-premium">PREMIUM</span>
            <h2 style="font-size: 2rem; margin-top: 10px;">Unlimited <span style="font-size: 1rem; color: var(--text-muted);">/ $9.99</span></h2>
        </div>
        
        <div style="flex-grow: 1;">
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 16px;">
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="zap" style="color: #f59e0b; width: 18px;"></i> Unlimited Global Messages
                </li>
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="zap" style="color: #f59e0b; width: 18px;"></i> No Friend Restrictions
                </li>
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="zap" style="color: #f59e0b; width: 18px;"></i> Instant Priority Delivery
                </li>
                <li style="display: flex; align-items: center; gap: 12px; font-size: 0.95rem;">
                    <i data-lucide="zap" style="color: #f59e0b; width: 18px;"></i> 24/7 Priority Support
                </li>
            </ul>
        </div>

        @if (Model.IsPremium)
        {
            <div style="margin-top: 40px; background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; padding: 12px; border-radius: 12px; text-align: center; color: #10b981; font-weight: 600;">
                <i data-lucide="check" style="width: 18px; vertical-align: middle;"></i> Subscription Active
            </div>
        }
        else
        {
            <button onclick="document.getElementById('payModal').style.display='flex'" class="btn-primary" style="margin-top: 40px; width: 100%; justify-content: center;">Upgrade Now</button>
        }
    </div>
</div>

<!-- Simple Payment Modal -->
<div id="payModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(10px); z-index: 2000; align-items: center; justify-content: center;">
    <div class="glass-card" style="width: 100%; max-width: 440px; padding: 40px;">
        <div style="text-align: center; margin-bottom: 30px;">
            <i data-lucide="credit-card" style="width: 48px; height: 48px; color: var(--primary); margin-bottom: 16px;"></i>
            <h3>Secure Checkout</h3>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Upgrade to Premium for $9.99/month</p>
        </div>
        <form asp-action="ActivatePremium" method="post">
            <div class="form-group">
                <label class="form-label">Card Number</label>
                <input class="form-input" placeholder="XXXX XXXX XXXX XXXX" required />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label class="form-label">Expiry</label>
                    <input class="form-input" placeholder="MM/YY" required />
                </div>
                <div class="form-group">
                    <label class="form-label">CVC</label>
                    <input class="form-input" placeholder="XXX" required />
                </div>
            </div>
            <button type="submit" class="btn-primary" style="width: 100%; justify-content: center; margin-top: 20px;">Confirm & Pay</button>
            <button type="button" onclick="document.getElementById('payModal').style.display='none'" class="btn-primary" style="width: 100%; margin-top: 10px; background: transparent; box-shadow: none; color: var(--text-muted);">Cancel</button>
        </form>
    </div>
</div>
