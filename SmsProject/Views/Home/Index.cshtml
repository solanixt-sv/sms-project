@model SmsProject.Models.ApplicationUser
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-header" style="margin-bottom: 50px;">
    <h1 class="text-gradient" style="font-size: 2.5rem; font-weight: 700; margin-bottom: 10px;">Welcome back, @Model.Username!</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem;">Manage your social circle and send secure messages with ease.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px;">
    <div class="glass-card">
        <div style="background: rgba(99, 102, 241, 0.1); width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i data-lucide="send" style="color: var(--primary); width: 30px; height: 30px;"></i>
        </div>
        <h3 style="font-size: 1.25rem; margin-bottom: 12px;">Send SMS</h3>
        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 0.95rem; line-height: 1.6;">Compose and send secure messages to your global contacts instantly.</p>
        <a asp-controller="Sms" asp-action="Index" class="btn-primary" style="width: 100%; justify-content: center;">Open Messages</a>
    </div>

    <div class="glass-card">
        <div style="background: rgba(236, 72, 153, 0.1); width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i data-lucide="users" style="color: var(--secondary); width: 30px; height: 30px;"></i>
        </div>
        <h3 style="font-size: 1.25rem; margin-bottom: 12px;">Social Circle</h3>
        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 0.95rem; line-height: 1.6;">Manage your friends, pending requests, and expand your network.</p>
        <a asp-controller="Social" asp-action="Friends" class="btn-primary" style="width: 100%; justify-content: center;">Friends List</a>
    </div>

    <div class="glass-card">
        <div style="background: rgba(139, 92, 246, 0.1); width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i data-lucide="settings" style="color: var(--accent); width: 30px; height: 30px;"></i>
        </div>
        <h3 style="font-size: 1.25rem; margin-bottom: 12px;">Account</h3>
        <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 0.95rem; line-height: 1.6;">Update your personal and professional profile details anytime.</p>
        <a asp-controller="Account" asp-action="Profile" class="btn-primary" style="width: 100%; justify-content: center;">Quick Profile</a>
    </div>
</div>
