@model SmsProject.Models.ApplicationUser
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header text-center" style="margin-bottom: 120px; padding-top: 60px;">
    <h1 class="page-title" style="font-size: 3rem; margin-bottom: 16px;">Welcome back, <span style="color: var(--indigo-light);">@Model.Username</span></h1>
    <p class="page-subtitle" style="font-size: 1.15rem; max-width: 600px; margin: 0 auto;">Experience the next generation of secure, global messaging. Connect with friends or manage your contacts.</p>
</div>

<div class="grid-3">
    <!-- Send SMS Card -->
    <div class="card card-glow" onclick="location.href='@Url.Action("Index", "Sms")'" style="cursor: pointer; display: flex; flex-direction: column; align-items: center; text-align: center;">
        <div class="flex-center icon-box icon-box-indigo" style="margin-bottom: 24px; width: 64px; height: 64px;">
            <i data-lucide="send"></i>
        </div>
        <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; color: var(--text);">Quick Message</h3>
        <p style="color: var(--text-secondary); margin-bottom: 20px; font-size: 0.95rem; line-height: 1.6;">Send SMS to your friends or contacts instantly.</p>
        <div style="margin-top: auto; width: 100%;">
            <a href="@Url.Action("Index", "Sms")" class="btn btn-primary" style="width: 100%; justify-content: center; background: #5568fe;">Go to Inbox</a>
        </div>
    </div>

    <!-- Social Circle Card -->
    <div class="card" onclick="location.href='@Url.Action("Friends", "Social")'" style="cursor: pointer; display: flex; flex-direction: column; align-items: center; text-align: center;">
        <div class="flex-center icon-box icon-box-pink" style="margin-bottom: 24px; width: 64px; height: 64px;">
            <i data-lucide="users"></i>
        </div>
        <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; color: var(--text);">Social Circle</h3>
        <p style="color: var(--text-secondary); margin-bottom: 20px; font-size: 0.95rem; line-height: 1.6;">Manage your friends and connections.</p>
        <div style="margin-top: auto; width: 100%;">
            <a href="@Url.Action("Friends", "Social")" class="btn btn-primary" style="width: 100%; justify-content: center; background: #5568fe;">View Friends</a>
        </div>
    </div>

    <!-- Premium Services Card -->
    <div class="card" onclick="location.href='@Url.Action("Index", "Service")'" style="cursor: pointer; display: flex; flex-direction: column; align-items: center; text-align: center;">
        <div class="flex-center icon-box icon-box-amber" style="margin-bottom: 24px; width: 64px; height: 64px;">
            <i data-lucide="package"></i>
        </div>
        <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; color: var(--text);">Service Packages</h3>
        <p style="color: var(--text-secondary); margin-bottom: 20px; font-size: 0.95rem; line-height: 1.6;">Activate new services and messaging plans.</p>
        <div style="margin-top: auto; width: 100%;">
            <a href="@Url.Action("Index", "Service")" class="btn btn-primary" style="width: 100%; justify-content: center; background: #5568fe;">Explore Services</a>
        </div>
    </div>
</div>

<div class="card mt-lg" style="background: linear-gradient(145deg, rgba(30,27,75,0.4), rgba(15,23,42,0.4));">
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
        <div style="display: flex; align-items: center; gap: 20px;">
            <div class="icon-box icon-box-emerald">
                <i data-lucide="shield-check"></i>
            </div>
            <div>
                <h4 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 4px;">System Status: Optimal</h4>
                <p style="color: var(--text-secondary); font-size: 0.9rem;">All services are running normally. Encryption active.</p>
            </div>
        </div>
        <div style="display: flex; gap: 12px;">
            <div class="badge badge-active"><i data-lucide="server" style="width:12px;"></i> Gateway Online</div>
            @if(Model.IsPremium) {
                <div class="badge badge-gold"><i data-lucide="star" style="width:12px;"></i> Premium</div>
            }
        </div>
    </div>
</div>
