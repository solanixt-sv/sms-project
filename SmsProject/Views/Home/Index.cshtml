@{
    ViewData["Title"] = "Dashboard";
}

<div class="container text-center">
    <div class="card glass-card mb-5">
        <h1 class="display-4">Welcome to Online SMS</h1>
        <p class="lead">Connect, Share, and Message effortlessly.</p>
    </div>

    @if (Context.Session.GetInt32("UserId") != null)
    {
        <div class="dashboard-grid">
            <div class="card glass-card stat-card">
                <i data-lucide="send" style="width: 48px; height: 48px; color: var(--primary);"></i>
                <h3 class="mt-3">Quick Message</h3>
                <p class="text-muted">Send SMS to your friends or contacts instantly.</p>
                <a asp-controller="Sms" asp-action="Index" class="btn-primary mt-3 d-inline-block">Go to Inbox</a>
            </div>

            <div class="card glass-card stat-card">
                <i data-lucide="users" style="width: 48px; height: 48px; color: #10b981;"></i>
                <h3 class="mt-3">Social Circle</h3>
                <p class="text-muted">Manage your friends and connections.</p>
                <a asp-controller="Social" asp-action="Friends" class="btn-primary mt-3 d-inline-block">View Friends</a>
            </div>

            <div class="card glass-card stat-card">
                <i data-lucide="package" style="width: 48px; height: 48px; color: #f59e0b;"></i>
                <h3 class="mt-3">Service Packages</h3>
                <p class="text-muted">Activate new services and messaging plans.</p>
                <a asp-controller="Service" asp-action="Index" class="btn-primary mt-3 d-inline-block">Explore Services</a>
            </div>
        </div>
    }
    else
    {
        <div class="card glass-card p-5">
            <h3>Join the network today</h3>
            <div class="mt-4" style="display: flex; gap: 1rem; justify-content: center;">
                <a asp-controller="Account" asp-action="Login" class="btn-primary">Sign In</a>
                <a asp-controller="Account" asp-action="Register" class="btn-secondary">Create Account</a>
            </div>
        </div>
    }
</div>
