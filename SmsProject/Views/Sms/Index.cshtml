@{
    ViewData["Title"] = "Secure Messaging";
}

<div class="page-header text-center">
    <h1 class="page-title">Command Center</h1>
    <p class="page-subtitle">Send encrypted messages directly to your contacts.</p>
</div>

<div style="display: grid; grid-template-columns: 340px 1fr; gap: 40px; align-items: start;">
    
    <!-- Sidebar -->
    <div style="display: flex; flex-direction: column; gap: 24px;">
        <div class="card" style="padding: 24px;">
            <h3 style="font-size: 1rem; font-weight: 700; margin-bottom: 20px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Quick Actions</h3>
            
            <a href="@Url.Action("Friends", "Social")" class="contact-item" style="text-decoration: none; display: flex;">
                <div class="icon-box icon-box-indigo" style="width: 40px; height: 40px;"><i data-lucide="users" style="width:18px;"></i></div>
                <div>
                    <div style="font-weight: 600; color: var(--text); font-size: 0.95rem;">Trust Network</div>
                    <div style="font-size: 0.8rem; color: var(--text-secondary);">Manage friends</div>
                </div>
            </a>
            
            <div class="divider" style="margin: 12px 0;"></div>

            <a href="@Url.Action("Contacts", "Social")" class="contact-item" style="text-decoration: none; display: flex;">
                <div class="icon-box icon-box-pink" style="width: 40px; height: 40px;"><i data-lucide="book-user" style="width:18px;"></i></div>
                <div>
                    <div style="font-weight: 600; color: var(--text); font-size: 0.95rem;">Address Book</div>
                    <div style="font-size: 0.8rem; color: var(--text-secondary);">Saved numbers</div>
                </div>
            </a>
        </div>

        <div class="card" style="background: rgba(139,92,246,0.05); border-color: rgba(139,92,246,0.1); padding: 24px;">
            <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                <i data-lucide="info" style="color: var(--violet); width: 20px; flex-shrink: 0;"></i>
                <h4 style="font-size: 0.95rem; font-weight: 600;">Message Limits</h4>
            </div>
            <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;">
                Standard accounts are limited to 5 messages/month for non-friends. Messaging friends is always unlimited.
            </p>
        </div>
    </div>

    <!-- Composer -->
    <div class="card card-glow" style="padding: 40px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
            <div>
                <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 4px;">Compose SMS</h2>
                <div style="display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: var(--emerald);">
                    <i data-lucide="lock" style="width:14px;"></i> End-to-end Encrypted
                </div>
            </div>
            <div class="icon-box icon-box-indigo" style="background: transparent; border: 1px solid var(--border);">
                <i data-lucide="message-square-plus"></i>
            </div>
        </div>

        <form id="smsForm">
            <div class="form-group">
                <label class="form-label">Recipient Mobile</label>
                <div class="input-icon-wrap">
                    <i data-lucide="smartphone" class="icon"></i>
                    <input type="text" id="receiverMobile" class="form-input" placeholder="e.g. 03001234567" required />
                </div>
            </div>

            <div class="form-group" style="margin-top: 28px;">
                <label class="form-label">Message Payload</label>
                <textarea id="messageBody" class="form-input" placeholder="Enter encrypted payload here..." maxlength="120"></textarea>
                
                <div class="char-bar">
                    <div id="charFill" class="char-bar-fill" style="width: 0%;"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin-top: 8px;">
                    <span id="charCountText" style="font-size: 0.8rem; font-weight: 600; color: var(--indigo-light);">0 / 120</span>
                    <span style="font-size: 0.8rem; color: var(--text-tertiary);">GSM standard length</span>
                </div>
            </div>

            <div style="margin-top: 40px; display: flex; align-items: center; gap: 20px;">
                <button type="button" onclick="sendSms()" class="btn btn-primary btn-lg" id="sendBtn">
                    Execute Transmission <i data-lucide="send" style="width: 18px;"></i>
                </button>
                <div id="statusAlert" style="display: none; flex-grow: 1;"></div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const messageBody = document.getElementById('messageBody');
        const charCountText = document.getElementById('charCountText');
        const charFill = document.getElementById('charFill');
        const statusAlert = document.getElementById('statusAlert');
        const sendBtn = document.getElementById('sendBtn');

        messageBody.addEventListener('input', () => {
            const len = messageBody.value.length;
            const percentage = (len / 120) * 100;
            
            charCountText.textContent = `${len} / 120`;
            charFill.style.width = `${percentage}%`;
            
            if (len >= 100) charFill.style.background = 'linear-gradient(to right, #f59e0b, #ef4444)';
            else charFill.style.background = 'linear-gradient(to right, var(--indigo), var(--violet))';
        });

        function showAlert(type, msg) {
            statusAlert.style.display = 'flex';
            statusAlert.className = `alert alert-${type}`;
            const icon = type === 'success' ? 'check-circle' : (type === 'error' ? 'x-circle' : 'loader');
            statusAlert.innerHTML = `<i data-lucide="${icon}" style="width:18px;"></i> ${msg}`;
            lucide.createIcons();
        }

        async function sendSms() {
            const mobile = document.getElementById('receiverMobile').value;
            const body = document.getElementById('messageBody').value;

            if (!mobile || !body) {
                showAlert('error', 'Payload incomplete. Fill all fields.');
                return;
            }

            showAlert('info', 'Encrypting and transmitting...');
            sendBtn.disabled = true;
            sendBtn.style.opacity = '0.7';

            try {
                const response = await fetch('/Sms/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `receiverMobile=${encodeURIComponent(mobile)}&body=${encodeURIComponent(body)}`
                });

                const result = await response.json();
                if (result.success) {
                    showAlert('success', 'Transmission successful.');
                    document.getElementById('smsForm').reset();
                    charCountText.textContent = "0 / 120";
                    charFill.style.width = "0%";
                    setTimeout(() => { statusAlert.style.display = 'none'; }, 4000);
                } else {
                    showAlert('error', result.message);
                }
            } catch (err) {
                showAlert('error', 'Network failure during transmission.');
            } finally {
                sendBtn.disabled = false;
                sendBtn.style.opacity = '1';
            }
        }
    </script>
}
