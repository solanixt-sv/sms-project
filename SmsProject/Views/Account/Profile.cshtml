@model SmsProject.Models.ApplicationUser
@{
    ViewData["Title"] = "User Profile";
}

<div class="page-header text-center">
    <h1 class="page-title">Profile Settings</h1>
    <p class="page-subtitle">Manage your identity and platform presence.</p>
</div>

<div class="app-container" style="max-width: 800px; padding: 0;">
    <div class="card" style="padding: 40px;">
        <!-- Avatar Header -->
        <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--border);">
            <div style="width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(135deg, var(--indigo), var(--violet)); display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 800; font-family: 'Plus Jakarta Sans'; box-shadow: var(--glow-indigo);">
                @Model.Username[0].ToString().ToUpper()
            </div>
            <div>
                <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 4px;">@Model.Username</h2>
                <div style="display: flex; gap: 12px; align-items: center;">
                    <span style="color: var(--text-secondary); font-size: 0.95rem;">@Model.Email</span>
                    @if (Model.IsPremium)
                    {
                        <span class="badge badge-gold">Premium Member</span>
                    }
                    else
                    {
                        <span class="badge" style="background: var(--surface-hover); color: var(--text-tertiary);">Standard</span>
                    }
                </div>
            </div>
        </div>

        <div class="tab-bar">
            <button class="tab-btn active" onclick="switchTab('personal')">Personal Identity</button>
            <button class="tab-btn" onclick="switchTab('professional')">Professional Intel</button>
        </div>

        <form asp-action="UpdateProfile" method="post">
            <!-- Personal Tab -->
            <div id="tab-personal" class="tab-panel active">
                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <div class="input-icon-wrap">
                            <i data-lucide="user" class="icon"></i>
                            <input name="FullName" value="@Model.FullName" class="form-input" placeholder="e.g. John Doe" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Date of Birth</label>
                        <div class="input-icon-wrap">
                            <i data-lucide="calendar" class="icon"></i>
                            <input name="DateOfBirth" type="date" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" class="form-input" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                     <label class="form-label">Primary Mobile</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="smartphone" class="icon"></i>
                        <input name="Mobile" value="@Model.Mobile" class="form-input" readonly style="opacity: 0.7; cursor: not-allowed;" />
                    </div>
                     <small style="color: var(--text-tertiary); font-size: 0.8rem; margin-top: 4px; display: block;">Mobile number cannot be changed after registration.</small>
                </div>

                <div class="form-group">
                    <label class="form-label">Location / Address</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="map-pin" class="icon"></i>
                        <input name="Address" value="@Model.Address" class="form-input" placeholder="City, Country" />
                    </div>
                </div>
            </div>

            <!-- Professional Tab -->
            <div id="tab-professional" class="tab-panel">
                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Organization</label>
                        <div class="input-icon-wrap">
                            <i data-lucide="building" class="icon"></i>
                            <input name="CompanyName" value="@Model.CompanyName" class="form-input" placeholder="Company Name" />
                        </div>
                    </div>
                     <div class="form-group">
                        <label class="form-label">Role / Title</label>
                        <div class="input-icon-wrap">
                            <i data-lucide="briefcase" class="icon"></i>
                            <input name="JobTitle" value="@Model.JobTitle" class="form-input" placeholder="e.g. Software Engineer" />
                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end;">
                <button type="submit" class="btn btn-primary btn-lg">Save Configuration</button>
            </div>
            
            @if (TempData["ProfileMsg"] != null)
            {
               <div class="alert alert-success mt-md">@TempData["ProfileMsg"]</div>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tabName) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            
            document.getElementById('tab-' + tabName).classList.add('active');
            event.currentTarget.classList.add('active');
        }
    </script>
}
