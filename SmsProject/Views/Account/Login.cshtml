@{
    ViewData["Title"] = "Login";
}

<div class="flex-center" style="min-height: calc(100vh - 200px);">
    <div class="card card-glow" style="width: 100%; max-width: 420px; padding: 48px;">
        <div class="text-center" style="margin-bottom: 40px;">
            <div class="icon-box icon-box-indigo" style="margin: 0 auto 20px; width: 56px; height: 56px;">
                <i data-lucide="fingerprint" style="width: 28px; height: 28px;"></i>
            </div>
            <h2 class="page-title" style="font-size: 1.8rem; margin-bottom: 8px;">Authentication Link</h2>
            <p class="text-muted">Enter credentials to access the secure grid.</p>
        </div>

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label class="form-label">Identifier (Username or Mobile)</label>
                <div class="input-icon-wrap">
                    <i data-lucide="user" class="icon"></i>
                    <input name="loginId" class="form-input" placeholder="e.g. jdoe99" required />
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 32px;">
                <label class="form-label">Passphrase</label>
                <div class="input-icon-wrap">
                    <i data-lucide="lock" class="icon"></i>
                    <input name="password" type="password" class="form-input" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg">
                Initiate Secure Session <i data-lucide="arrow-right" style="width: 18px;"></i>
            </button>
        </form>

        <div class="text-center mt-lg" style="border-top: 1px solid var(--border); padding-top: 24px;">
            <p class="text-muted" style="font-size: 0.9rem;">No credentials yet? 
                <a asp-action="Register" style="color: var(--indigo-light); text-decoration: none; font-weight: 600; margin-left: 4px;">Request Access</a>
            </p>
        </div>
    </div>
</div>
