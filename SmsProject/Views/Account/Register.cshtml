@{
    ViewData["Title"] = "Register";
}

<div class="flex-center" style="min-height: calc(100vh - 150px); padding: 40px 0;">
    <div class="card card-glow" style="width: 100%; max-width: 520px; padding: 48px;">
        <div class="text-center" style="margin-bottom: 40px;">
            <div class="icon-box icon-box-pink" style="margin: 0 auto 20px; width: 56px; height: 56px;">
                <i data-lucide="user-plus" style="width: 28px; height: 28px;"></i>
            </div>
            <h2 class="page-title" style="font-size: 1.8rem; margin-bottom: 8px;">Network Registration</h2>
            <p class="text-muted">Generate your credentials for the secure messaging grid.</p>
        </div>

        <form asp-action="Register" method="post">
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Identifier (Username)</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="at-sign" class="icon"></i>
                        <input name="Username" class="form-input" placeholder="e.g. nova99" required />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Communication Node (Email)</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="mail" class="icon"></i>
                        <input name="Email" type="email" class="form-input" placeholder="node@sector.net" required />
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mobile Terminal Number</label>
                <div class="input-icon-wrap">
                    <i data-lucide="smartphone" class="icon"></i>
                    <input name="Mobile" class="form-input" placeholder="Required for routing. e.g. 03001234567" required />
                </div>
            </div>

            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Passphrase</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="key" class="icon"></i>
                        <input name="Password" type="password" class="form-input" placeholder="••••••••" required />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Verify Passphrase</label>
                    <div class="input-icon-wrap">
                        <i data-lucide="key" class="icon"></i>
                        <input name="ConfirmPassword" type="password" class="form-input" placeholder="••••••••" required />
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 32px;">
                <label class="form-label">Security Clearance Code</label>
                <div class="input-icon-wrap">
                    <i data-lucide="shield" class="icon"></i>
                    <input name="VerificationCode" class="form-input" placeholder="Demo clearance: 1234" required />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-full btn-lg">
                Authorize & Connect <i data-lucide="zap" style="width: 18px;"></i>
            </button>
        </form>

        <div class="text-center mt-lg" style="border-top: 1px solid var(--border); padding-top: 24px;">
            <p class="text-muted" style="font-size: 0.9rem;">Credentials already active? 
                <a asp-action="Login" style="color: var(--pink); text-decoration: none; font-weight: 600; margin-left: 4px;">Initiate Session</a>
            </p>
        </div>
    </div>
</div>
