@{
    ViewData["Title"] = "Register";
}

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 40px 0;">
    <div class="glass-card" style="width: 100%; max-width: 500px;">
        <div style="text-align: center; margin-bottom: 32px;">
            <div style="display: inline-flex; background: rgba(236, 72, 153, 0.1); padding: 16px; border-radius: 20px; margin-bottom: 20px;">
                <i data-lucide="user-plus" style="color: var(--secondary); width: 32px; height: 32px;"></i>
            </div>
            <h2 style="font-size: 1.75rem; font-weight: 700;">Join Online SMS</h2>
            <p style="color: var(--text-muted); font-size: 0.95rem;">Experience secure and global messaging</p>
        </div>

        <form asp-action="Register" method="post">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <input name="Username" class="form-input" placeholder="Desired username" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input name="Email" type="email" class="form-input" placeholder="mail@example.com" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mobile Number</label>
                <input name="Mobile" class="form-input" placeholder="e.g. 03001234567" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input name="Password" type="password" class="form-input" placeholder="••••••••" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm</label>
                    <input name="ConfirmPassword" type="password" class="form-input" placeholder="••••••••" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Verification Code (Demo: 1234)</label>
                <input name="VerificationCode" class="form-input" placeholder="Enter code" required />
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
                Create Account <i data-lucide="rocket" style="width: 18px;"></i>
            </button>
        </form>

        <div style="text-align: center; margin-top: 32px; border-top: 1px solid var(--glass-border); padding-top: 24px;">
            <p style="color: var(--text-muted); font-size: 0.9rem;">Already have an account? 
                <a asp-action="Login" style="color: var(--primary); text-decoration: none; font-weight: 600;">Sign in here</a>
            </p>
        </div>
    </div>
</div>
